# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design source files (heavy binaries — keep exports, not sources)
design/figma/*.fig
design/after-effects/**/*.aep
design/after-effects/**/*.aepx
**/*.psd
**/*.ai
**/*.sketch

# motion source files (keep Lottie JSON + final MP4, not project files)
motion/**/*.aep
motion/**/*.aepx

# macOS
.DS_Store
**/.DS_Store

# research screenshots (preview images, not source)
/research/

# design source files (large binaries)
/design/

# motion source files
/motion/

# deck PDFs
/deck/
